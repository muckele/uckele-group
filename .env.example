PORT=8787
PUBLIC_SITE_URL=https://www.uckelegroup.com
VITE_PUBLIC_SITE_URL=https://www.uckelegroup.com
VITE_PUBLIC_CONTACT_EMAIL=mathew@uckelegroup.com
VITE_PUBLIC_CONTACT_PHONE=914.361.9153
VITE_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/mathew-uckele

# Storage
STORAGE_PROVIDER=sqlite
SQLITE_PATH=./data/uckele-group.sqlite
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
