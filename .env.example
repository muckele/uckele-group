# SQLITE_PATH=/data/uckele-group.sqlite

# Email delivery
DELIVERY_PROVIDER=console
LEAD_NOTIFICATION_EMAIL=mathew@uckelegroup.com

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Uckele Group <leads@yourdomain.com>
RESEND_REPLY_TO=mathew@uckelegroup.com

# Formspree
FORMSPREE_ENDPOINT=

# EmailJS
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# CRM forwarding
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# Spam protection
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=6
MIN_SUBMIT_TIME_MS=4000
SPAM_SCORE_THRESHOLD=50

# Admin dashboard
ADMIN_AUTH_MODE=hybrid
ADMIN_EMAIL=mathew@uckelegroup.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
ADMIN_SESSION_SECRET=replace-this-with-a-long-random-string
ADMIN_MAGIC_LINK_SECRET=replace-this-with-a-second-random-string
ADMIN_MAGIC_LINK_TTL_MS=1200000
ADMIN_ALLOW_PASSWORD_AUTH=true
ADMIN_SESSION_MAX_AGE_MS=43200000

# Workflow defaults
DEFAULT_LEAD_ASSIGNEE=Mathew Uckele
DEFAULT_FOLLOW_UP_DELAY_HOURS=24

# Secure documents
SECURE_DOCUMENTS_TOKEN_SECRET=replace-this-with-a-third-random-string
SECURE_DOCUMENTS_REQUEST_TTL_MS=1209600000
SECURE_DOCUMENTS_MAX_UPLOAD_BYTES=8388608
SECURE_DOCUMENTS_STORAGE_DIR=./data/secure-documents
